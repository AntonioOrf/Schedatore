{
  "name": "Schedatore",
  "version": "1.0.0",
  "description": "Gestionale per manoscritti medievali",
  "main": "src/main/main.js",
  "scripts": {
    "build-css": "npx @tailwindcss/cli -i ./src/renderer/css/input.css -o ./src/renderer/css/tailwind.css --minify",
    "start": "npm run build-css && electron .",
    "pack": "npm run build-css && electron-builder --win"
  },
  "build": {
    "appId": "com.antonioorf.Schedatore",
    "productName": "Schedatore",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName} Setup.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AntonioOrf",
        "repo": "Schedatore"
      }
    ]
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "electron-updater": "^6.8.3"
  }
}
