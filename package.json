{
  "name": "archiview",
  "version": "1.0.10",
  "description": "Gestionale per manoscritti medievali",
  "author": "Antonio Orf",
  "repository": {
    "type": "git",
    "url": "https://github.com/AntonioOrf/ArchiView.git"
  },
  "main": "src/main/main.js",
  "scripts": {
    "build-css": "npx @tailwindcss/cli -i ./src/renderer/css/input.css -o ./src/renderer/css/tailwind.css --minify",
    "start": "npm run build-css && electron .",
    "pack": "npm run build-css && electron-builder --win",
    "publish-app": "npm run build-css && electron-builder --win -p always"
  },
  "build": {
    "generateUpdatesFilesForAllChannels": true,
    "appId": "com.antonioorf.archiview",
    "productName": "ArchiView",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AntonioOrf",
        "repo": "ArchiView",
        "releaseType": "release"
      }
    ]
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "electron-updater": "^6.8.3"
  }
}
