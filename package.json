{
  "name": "Schedatore",
  "version": "1.0.0",
  "description": "Gestionale per manoscritti medievali",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --win"
  },
  "build": {
    "appId": "com.antonioorf.Schedatore",
    "productName": "Schedatore",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "${productName} Portable.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "archiver": "^8.0.0"
  }
}
